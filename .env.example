# ──────────────────────────────────────────────────────────────────
# Lumare environment variables — copy to .env and fill in.
# Everything is optional for dev — the stack runs with no vars set.
# ──────────────────────────────────────────────────────────────────

# ─── Database ────────────────────────────────────────────────────
# SQLite default (single-machine dev). Set to a Postgres DSN for cloud.
#   DATABASE_URL=postgresql://user:pass@host:5432/lumare
DATABASE_URL=data/lumare.db


# ─── Production hardening ────────────────────────────────────────
# CORS — comma-separated origins to allow in production. Localhost is
# always allowed; this adds your hosted frontend domain(s).
#   LUMARE_CORS_ORIGINS=https://app.lumare.io,https://lumare.vercel.app
LUMARE_CORS_ORIGINS=

# JWT secret for multi-tenant mode. Unset → single-tenant (default).
# Generate with: openssl rand -hex 32
LUMARE_JWT_SECRET=

# Sentry DSN for production error tracking. Unset → no-op.
SENTRY_DSN=
SENTRY_TRACES_SAMPLE=0.05
LUMARE_ENV=development
LUMARE_RELEASE=1.0.0


# ─── Live trading (real-money safety triple-lock) ────────────────
# ALL THREE must be set to permit real-money orders:
#   1. LUMARE_ALLOW_LIVE=1
#   2. The relevant broker's API key+secret
#   3. The bot must be started with mode="live"
LUMARE_ALLOW_LIVE=0


# ─── Crypto data + execution ─────────────────────────────────────
# Blowfin (perpetuals, optional — falls back to Coinbase public if unset)
BLOWFIN_API_KEY=
BLOWFIN_API_SECRET=
BLOWFIN_PASSPHRASE=

# Coinbase Advanced Trade (spot crypto live execution)
COINBASE_API_KEY=
COINBASE_API_SECRET=


# ─── Equity data + execution ─────────────────────────────────────
# Polygon (Pro recommended for tick-level data; free uses yfinance)
POLYGON_API_KEY=

# Alpaca (US equities live execution)
# Default base URL is paper-api.alpaca.markets — flip to api.alpaca.markets
# ONLY when you're ready to send real-money orders.
ALPACA_API_KEY=
ALPACA_API_SECRET=
ALPACA_BASE_URL=https://paper-api.alpaca.markets


# ─── Macro + research feeds ──────────────────────────────────────
FRED_API_KEY=
PERPLEXITY_API_KEY=
UNUSUAL_WHALES_API_KEY=
QUIVERQUANT_API_KEY=


# ─── Bot tuning (optional overrides) ─────────────────────────────
# Bypass the production score threshold for diagnostic backtests
# LUMARE_DIAG_THRESHOLD=50


# ─── Frontend ────────────────────────────────────────────────────
# Set in your hosting platform's frontend env, not here:
#   NEXT_PUBLIC_API_URL=https://api.yourdomain.com
