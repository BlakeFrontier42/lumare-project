# LUMARE — Environment Variables
# Copy this file to .env.local and fill in your keys

# ============================================
# MARKET DATA
# ============================================

# Polygon.io — Live/historical price data
# Get from: https://polygon.io (Starter plan $29/mo)
POLYGON_API_KEY=

# ============================================
# AI ENGINE
# ============================================

# Anthropic Claude — AI analysis, portfolio builder, sentiment
# Get from: https://console.anthropic.com
ANTHROPIC_API_KEY=

# ============================================
# TRADE EXECUTION — EQUITIES
# ============================================

# Alpaca — Paper + live trading
# Get from: https://alpaca.markets
ALPACA_KEY=
ALPACA_SECRET=

# ============================================
# TRADE EXECUTION — CRYPTO (Phase 1)
# ============================================

# Blowfin — Crypto perpetual futures
# Get from: https://blowfin.com
BLOWFIN_API_KEY=
BLOWFIN_SECRET=

# ============================================
# ALTERNATIVE DATA
# ============================================

# Unusual Whales — Options flow data
# Get from: https://unusualwhales.com ($50/mo)
UNUSUAL_WHALES_KEY=

# Quiver Quant — Congressional trades
# Get from: https://quiverquant.com (free tier)
QUIVER_QUANT_KEY=

# FRED — Macro economic data (free, optional key)
# Get from: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# ============================================
# AUTH
# ============================================

# Supabase — Authentication + Database
# Get from: https://supabase.com
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ============================================
# PAYMENTS
# ============================================

# Stripe — Subscription billing
# Get from: https://stripe.com
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# ============================================
# HOSTING
# ============================================
NEXT_PUBLIC_APP_URL=https://lumare.app
